{{define "fast-history"}} {{if .Fasts}}
<section class="py-3">
    <div
        class="d-flex justify-content-between align-items-center mb-2"
    >
        <h2 class="mb-0">History</h2>
    </div>

    <div class="accordion" id="fastHistoryAccordion">
        {{range .Fasts}} {{template "fast-tile" .}} {{end}}
    </div>
</section>
{{else}} {{end}} {{end}}
