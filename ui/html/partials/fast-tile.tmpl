{{define "fast-tile"}}
<div class="accordion-item">
    <h2 class="accordion-header" id="{{printf "heading-%d" .ID}}">
        <button
            class="accordion-button collapsed"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="{{printf "#collapse-%d" .ID}}"
            aria-expanded="false"
            aria-controls="{{printf "collapse-%d" .ID}}"
        >
            <div
                class="w-100 d-flex justify-content-between align-items-center me-3"
            >
                <div>
                    <div class="fw-semibold">{{fastDurationText .}}</div>
                    <div class="small text-muted">
                        {{fastRangeText .}}
                    </div>
                </div>
                <span class="badge bg-success ms-3">Goal hit</span>
            </div>
        </button>
    </h2>
    <div
        id="{{printf "collapse-%d" .ID}}"
        class="accordion-collapse collapse"
        aria-labelledby="{{printf "heading-%d" .ID}}"
        data-bs-parent="#fastHistoryAccordion"
    >
        <div class="accordion-body">
            <div>
                <p class="text-muted mb-3">
                    You completed your full target and matched your
                    planned fasting window exactly.
                </p>
            </div>

            <ul class="list-group mb-0">
                <li
                    class="list-group-item d-flex justify-content-between align-items-center"
                >
                    <span>Started</span>
                    <span class="text-muted">{{humanDate .StartTime}}</span>
                </li>
                <li
                    class="list-group-item d-flex justify-content-between align-items-center"
                >
                    <span>Ended</span>
                    <span class="text-muted">{{humanDate .EndTime}}</span>
                </li>
                <li
                    class="list-group-item d-flex justify-content-between align-items-center"
                >
                    <span>Duration</span>
                    <span class="text-muted">{{completedDurationText .}}</span>
                </li>
                <li
                    class="list-group-item d-flex justify-content-between align-items-center"
                >
                    <span>Goal</span>
                    <span class="text-muted">{{.GoalSeconds}} hours</span>
                </li>
            </ul>

            <div class="py-3 d-flex gap-2">
                <button class="btn btn-sm btn-outline-secondary">
                    Edit fast
                </button>
                <form action="/fast/{{.ID}}/delete" method="POST">
                  <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>
{{end}}
