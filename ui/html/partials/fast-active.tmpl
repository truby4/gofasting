{{define "fast-active"}}
<section class="py-3" id="active-fast" data-start-time="{{.Fast.StartTime.Format "2006-01-02T15:04:05Z07:00"}}" data-goal="{{.Fast.GoalSeconds}}">
    <h1 class="display-6">You're fasting!</h1>
    <p id="elapsed-timer" class="display-1">00:00:00</p>
    <p class="lead">
        You are <span id="fast-percent">0%</span> of the way through your current fast.
    </p>

    <div class="progress mb-4" role="progressbar" aria-label="Fast progress" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" style="height: 26px">
        <div id="progress-bar" class="progress-bar text-bg-info" style="width: 0%">0%</div>
    </div>

    <ul class="list-group mb-3">
        <li class="list-group-item d-flex justify-content-between align-items-center">
            <span>Started</span>
            <span class="text-muted">{{humanDate .Fast.StartTime}}</span>
        </li>
        <li class="list-group-item d-flex justify-content-between align-items-center">
            <span>Goal</span>
            <span class="text-muted">{{goalText .Fast.GoalSeconds}}</span>
        </li>
        <li class="list-group-item d-flex justify-content-between align-items-center">
            <span>Expected end</span>
            <span class="text-muted">{{humanDate .Fast.ExpectedEnd}}</span>
        </li>
    </ul>

    <form action="/fast/end" method="POST">
    <input type='hidden' name='csrf_token' value='{{.CSRFToken}}'>
      <button class="btn btn-danger mb-4 px-3" type="submit">End fast now</button>
    </form>
</section>
<script src="/static/js/active-fast.js"></script>
{{end}}
